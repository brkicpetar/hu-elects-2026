# ── Anthropic API (translation) ────────────────────────────────────────────────
# Used to translate Hungarian → English for news, tweets, and Facebook posts.
# Get your key at: https://console.anthropic.com/
# Translation uses claude-haiku (cheapest model, ~$0.001 per news refresh)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
